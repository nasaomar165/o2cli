{
  // ─── Fast Profile ─────────────────────────────────────────
  // Small, fast model for quick one-liners.
  // Usage: o2cli ask "list files" --profile fast
  "fast": {
    "provider": "lmstudio",
    "base_url": "http://localhost:1234/v1",
    "model": "qwen3.5",
    "temperature": 0.0,
    "max_tokens": 256
  },

  // ─── Powerful Profile ─────────────────────────────────────
  // Large model for complex multi-step commands or chat.
  // Usage: o2cli chat --profile powerful
  "powerful": {
    "provider": "ollama",
    "base_url": "http://localhost:11434/v1",
    "model": "llama3.2",
    "temperature": 0.2,
    "max_tokens": 2048
  },

  // ─── Code Profile ─────────────────────────────────────────
  // Code-specialized model for programming tasks.
  "code": {
    "provider": "ollama",
    "base_url": "http://localhost:11434/v1",
    "model": "codellama",
    "temperature": 0.1,
    "max_tokens": 1024
  },

  // ─── Creative Profile ─────────────────────────────────────
  // Higher temperature for exploratory / brainstorming tasks.
  "creative": {
    "provider": "lmstudio",
    "base_url": "http://localhost:1234/v1",
    "model": "mistral-instruct",
    "temperature": 0.7,
    "max_tokens": 1024
  },

  // ─── Remote Profile ──────────────────────────────────────
  // Example: connect to Ollama on another machine.
  // [SECURITY] base_url must NOT be a private IP unless localhost.
  //            Use a VPN/SSH tunnel for remote access.
  "remote": {
    "provider": "ollama",
    "base_url": "http://192.168.1.100:11434/v1",
    "model": "llama3.2",
    "temperature": 0.1,
    "max_tokens": 512
  }
}
